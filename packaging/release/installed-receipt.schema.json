{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2lab-ai/dbotter/packaging/release/dbotter.installed-receipt.v1.schema.json",
  "title": "dbotter.installed-receipt.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "started_at",
    "finished_at",
    "source",
    "build",
    "release",
    "formula",
    "install",
    "identity",
    "config_contract",
    "checks",
    "ax",
    "external_export_verifier",
    "assertions"
  ],
  "properties": {
    "schema": {"const": "dbotter.installed-receipt.v1"},
    "started_at": {"$ref": "#/$defs/timestamp"},
    "finished_at": {"$ref": "#/$defs/timestamp"},
    "source": {"$ref": "#/$defs/source"},
    "build": {"$ref": "#/$defs/build"},
    "release": {"$ref": "#/$defs/release"},
    "formula": {"$ref": "#/$defs/formula"},
    "install": {"$ref": "#/$defs/install"},
    "identity": {"$ref": "#/$defs/identity"},
    "config_contract": {"$ref": "#/$defs/config_contract"},
    "checks": {"$ref": "#/$defs/checks"},
    "ax": {"$ref": "#/$defs/ax"},
    "external_export_verifier": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/export_verdict"}
    },
    "assertions": {"$ref": "#/$defs/assertions"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "config_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read_versions", "write_version", "migration_backup_suffix"],
      "properties": {
        "read_versions": {"const": [1, 2]},
        "write_version": {"const": 2},
        "migration_backup_suffix": {"const": ".v1.bak"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "commit", "expected_sha", "run_id", "run_attempt"],
      "properties": {
        "kind": {"const": "ci_expected_sha"},
        "commit": {"$ref": "#/$defs/git_sha"},
        "expected_sha": {"$ref": "#/$defs/git_sha"},
        "run_id": {"type": "integer", "minimum": 1},
        "run_attempt": {"type": "integer", "minimum": 1}
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "arch", "profile", "features", "rustc_version", "cargo_version", "unsigned_executable_sha256"],
      "properties": {
        "target": {"enum": ["aarch64-apple-darwin", "x86_64-apple-darwin"]},
        "arch": {"enum": ["aarch64", "x86_64"]},
        "profile": {"const": "release"},
        "features": {"const": ["desktop", "mongodb"]},
        "rustc_version": {"type": "string", "pattern": "^rustc [0-9]+\\.[0-9]+\\.[0-9]+"},
        "cargo_version": {"type": "string", "pattern": "^cargo [0-9]+\\.[0-9]+\\.[0-9]+"},
        "unsigned_executable_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "manifest_url", "manifest_sha256", "version"],
      "properties": {
        "tag": {"type": "string"},
        "manifest_url": {"type": "string", "format": "uri"},
        "manifest_sha256": {"$ref": "#/$defs/sha256"},
        "version": {"type": "string"}
      }
    },
    "formula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit", "name", "version", "prefix"],
      "properties": {
        "repository": {"const": "2lab-ai/homebrew-tap"},
        "commit": {"$ref": "#/$defs/git_sha"},
        "name": {"const": "dbotter-preview"},
        "version": {"type": "string"},
        "prefix": {"type": "string", "pattern": "^/"}
      }
    },
    "file_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "realpath", "device", "inode", "bytes", "sha256", "codesign_valid"],
      "properties": {
        "path": {"type": "string", "pattern": "^/"},
        "realpath": {"type": "string", "pattern": "^/"},
        "device": {"type": "integer", "minimum": 1},
        "inode": {"type": "integer", "minimum": 1},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "codesign_valid": {"type": "boolean"}
      }
    },
    "shim_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "realpath", "device", "inode", "sha256"],
      "properties": {
        "path": {"type": "string", "pattern": "^/"},
        "realpath": {"type": "string", "pattern": "^/"},
        "device": {"type": "integer", "minimum": 1},
        "inode": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_app_path", "resolved_app_path", "bundle_id", "arch", "executable", "cli_shim"],
      "properties": {
        "requested_app_path": {"type": "string", "pattern": "^/"},
        "resolved_app_path": {"type": "string", "pattern": "^/"},
        "bundle_id": {"const": "ai.2lab.dbotter.preview"},
        "arch": {"enum": ["aarch64", "x86_64"]},
        "executable": {"$ref": "#/$defs/file_identity"},
        "cli_shim": {"$ref": "#/$defs/shim_identity"}
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package_version", "channel", "build_id", "source_sha", "target", "arch"],
      "properties": {
        "package_version": {"type": "string"},
        "channel": {"const": "preview"},
        "build_id": {"type": "string"},
        "source_sha": {"$ref": "#/$defs/git_sha"},
        "target": {"enum": ["aarch64-apple-darwin", "x86_64-apple-darwin"]},
        "arch": {"enum": ["aarch64", "x86_64"]}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "config_contract", "shim_identity", "bundle_identity", "executable_hash", "codesign", "check", "exec", "mysql_browse", "redis_browse", "redis_inspect"],
      "properties": {
        "version": {"type": "boolean"},
        "config_contract": {"type": "boolean"},
        "shim_identity": {"type": "boolean"},
        "bundle_identity": {"type": "boolean"},
        "executable_hash": {"type": "boolean"},
        "codesign": {"type": "boolean"},
        "check": {"type": "boolean"},
        "exec": {"type": "boolean"},
        "mysql_browse": {"type": "boolean"},
        "redis_browse": {"type": "boolean"},
        "redis_inspect": {"type": "boolean"}
      }
    },
    "pid_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["realpath", "device", "inode", "sha256"],
      "properties": {
        "realpath": {"type": "string", "pattern": "^/"},
        "device": {"type": "integer", "minimum": 1},
        "inode": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "ax": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_path", "pid", "stale_process_disposition", "pid_executable", "author_ids", "action_ids", "public_codes"],
      "properties": {
        "app_path": {"type": "string", "pattern": "^/"},
        "pid": {"type": "integer", "minimum": 1},
        "stale_process_disposition": {"enum": ["none", "terminated"]},
        "pid_executable": {"$ref": "#/$defs/pid_identity"},
        "author_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-z0-9_.:-]+$"}},
        "action_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-zA-Z0-9_.:-]+$"}},
        "public_codes": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}}
      }
    },
    "export_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_id", "expected_sha256", "actual_sha256", "verdict"],
      "properties": {
        "fixture_id": {"enum": ["seeded.csv", "seeded.tsv", "seeded.json"]},
        "expected_sha256": {"$ref": "#/$defs/sha256"},
        "actual_sha256": {"$ref": "#/$defs/sha256"},
        "verdict": {"type": "boolean"}
      }
    },
    "assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_match", "build_match", "manifest_valid", "release_match", "formula_match", "app_path_exact", "pid_identity", "identity_exact", "config_contract_exact", "shim_same_executable", "executable_hash_match", "codesign_valid", "cli_contracts", "live_contracts", "accessibility", "contrast", "recovery_totality", "clipboard", "disclosure", "export", "credential_leak", "user_content_leak", "overall"],
      "properties": {
        "source_match": {"type": "boolean"},
        "build_match": {"type": "boolean"},
        "manifest_valid": {"type": "boolean"},
        "release_match": {"type": "boolean"},
        "formula_match": {"type": "boolean"},
        "app_path_exact": {"type": "boolean"},
        "pid_identity": {"type": "boolean"},
        "identity_exact": {"type": "boolean"},
        "config_contract_exact": {"type": "boolean"},
        "shim_same_executable": {"type": "boolean"},
        "executable_hash_match": {"type": "boolean"},
        "codesign_valid": {"type": "boolean"},
        "cli_contracts": {"type": "boolean"},
        "live_contracts": {"type": "boolean"},
        "accessibility": {"type": "boolean"},
        "contrast": {"type": "boolean"},
        "recovery_totality": {"type": "boolean"},
        "clipboard": {"type": "boolean"},
        "disclosure": {"type": "boolean"},
        "export": {"type": "boolean"},
        "credential_leak": {"type": "boolean"},
        "user_content_leak": {"type": "boolean"},
        "overall": {"type": "boolean"}
      }
    }
  }
}
