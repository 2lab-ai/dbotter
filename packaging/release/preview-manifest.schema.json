{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/2lab-ai/dbotter/packaging/release/dbotter.preview-manifest.v1.schema.json",
  "title": "dbotter.preview-manifest.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tag",
    "source_sha",
    "version",
    "package_version",
    "config_contract",
    "run_id",
    "run_attempt",
    "created_at",
    "artifacts"
  ],
  "properties": {
    "tag": {
      "type": "string",
      "pattern": "^preview-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{6}-[1-9][0-9]*-[1-9][0-9]*-[0-9a-f]{12}$"
    },
    "source_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]{6}\\.[1-9][0-9]*\\.[1-9][0-9]*$"
    },
    "package_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "config_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read_versions", "write_version", "migration_backup_suffixes"],
      "properties": {
        "read_versions": {"type": "array", "const": [1, 2, 3]},
        "write_version": {"type": "integer", "const": 3},
        "migration_backup_suffixes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["1", "2"],
          "properties": {
            "1": {"type": "string", "const": ".v1.bak"},
            "2": {"type": "string", "const": ".v2.bak"}
          }
        }
      }
    },
    "run_id": {"type": "integer", "minimum": 1},
    "run_attempt": {"type": "integer", "minimum": 1},
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/artifact"}
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact": {
      "oneOf": [
        {"$ref": "#/$defs/macosArtifact"},
        {"$ref": "#/$defs/linuxArtifact"}
      ]
    },
    "macosArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "arch",
        "kind",
        "url",
        "bytes",
        "sha256",
        "embedded_executable_sha256",
        "bundle_id",
        "bundle_short_version",
        "bundle_build_version"
      ],
      "properties": {
        "target": {
          "enum": ["aarch64-apple-darwin", "x86_64-apple-darwin"]
        },
        "arch": {"enum": ["aarch64", "x86_64"]},
        "kind": {"const": "macos-app-tar-gz"},
        "url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "embedded_executable_sha256": {"$ref": "#/$defs/sha256"},
        "bundle_id": {"const": "ai.2lab.dbotter.preview"},
        "bundle_short_version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
        },
        "bundle_build_version": {
          "type": "string",
          "pattern": "^[1-9][0-9]*\\.[1-9][0-9]*$"
        }
      },
      "allOf": [
        {
          "if": {"properties": {"target": {"const": "aarch64-apple-darwin"}}},
          "then": {"properties": {"arch": {"const": "aarch64"}}}
        },
        {
          "if": {"properties": {"target": {"const": "x86_64-apple-darwin"}}},
          "then": {"properties": {"arch": {"const": "x86_64"}}}
        }
      ]
    },
    "linuxArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "arch",
        "kind",
        "url",
        "bytes",
        "sha256",
        "executable_mode"
      ],
      "properties": {
        "target": {
          "enum": ["aarch64-unknown-linux-gnu", "x86_64-unknown-linux-gnu"]
        },
        "arch": {"enum": ["aarch64", "x86_64"]},
        "kind": {"const": "linux-native-executable"},
        "url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "executable_mode": {"const": "0755"}
      },
      "allOf": [
        {
          "if": {"properties": {"target": {"const": "aarch64-unknown-linux-gnu"}}},
          "then": {"properties": {"arch": {"const": "aarch64"}}}
        },
        {
          "if": {"properties": {"target": {"const": "x86_64-unknown-linux-gnu"}}},
          "then": {"properties": {"arch": {"const": "x86_64"}}}
        }
      ]
    }
  }
}
